using System.ComponentModel.DataAnnotations;
using System.ComponentModel.DataAnnotations.Schema;

namespace KeyUpdate.Models
{
    [Table("manifest")]
    public class Manifest
    {
        [Key]
        [Column("id")]
        public long Id { get; set; }

        [Required(ErrorMessage = "O manifest_id é obrigatório.")]
        [Column("manifest_id")]
        [Display(Name = "Manifest ID")]
        public long ManifestId { get; set; }

        [Required(ErrorMessage = "O caminho do arquivo é obrigatório.")]
        [StringLength(255)]
        [Column("path")]
        [Display(Name = "Caminho")]
        public string Path { get; set; } = string.Empty;

        [Required(ErrorMessage = "O SHA256 é obrigatório.")]
        [StringLength(64)]
        [Column("sha256")]
        [Display(Name = "SHA256")]
        public string Sha256 { get; set; } = string.Empty;

        [Required(ErrorMessage = "O tamanho é obrigatório.")]
        [Column("size")]
        [Display(Name = "Tamanho")]
        public long Size { get; set; }

        [Column("regsvr32")]
        [Display(Name = "RegSvr32")]
        public bool Regsvr32 { get; set; }

        [Column("core")]
        [Display(Name = "Core")]
        public bool Core { get; set; }

        [Column("ativo")]
        [Display(Name = "Ativo")]
        public bool Ativo { get; set; } = true;

        // Propriedade computada para exibir apenas o nome do arquivo
        [NotMapped]
        public string NomeArquivo => System.IO.Path.GetFileName(Path);

        // Propriedade computada para formatar o tamanho
        [NotMapped]
        public string TamanhoFormatado
        {
            get
            {
                string[] sizes = { "B", "KB", "MB", "GB" };
                double len = Size;
                int order = 0;
                while (len >= 1024 && order < sizes.Length - 1)
                {
                    order++;
                    len = len / 1024;
                }
                return $"{len:0.##} {sizes[order]}";
            }
        }
    }
}
