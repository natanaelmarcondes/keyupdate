@model IEnumerable<KeyUpdate.Models.Manifest>

@{
    ViewData["Title"] = "Arquivos do Manifest";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2 class="page-title">
                    <i class="bi bi-file-earmark-zip me-2"></i>Arquivos do Manifest
                </h2>
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
                    <i class="bi bi-plus-circle me-1"></i>Adicionar Arquivo
                </button>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle" id="manifestTable">
                        <thead class="table-light">
                            <tr>
                                <th>Arquivo</th>
                                <th>SHA256</th>
                                <th class="text-center" style="width: 100px;">RegSvr32</th>
                                <th class="text-center" style="width: 100px;">Core</th>
                                <th class="text-center" style="width: 100px;">Ativo</th>
                                <th class="text-center" style="width: 120px;">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <i class="bi bi-file-earmark me-2 text-primary"></i>
                                        <strong>@item.Arquivo</strong>
                                    </td>
                                    <td>
                                        <code class="text-muted" style="font-size: 0.85rem;">@item.Sha256</code>
                                    </td>
                                    <td class="text-center">
                                        <div class="form-check form-switch d-inline-block">
                                            <input class="form-check-input toggle-field" 
                                                   type="checkbox" 
                                                   data-id="@item.Id" 
                                                   data-field="regsvr32"
                                                   @(item.Regsvr32 ? "checked" : "")>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="form-check form-switch d-inline-block">
                                            <input class="form-check-input toggle-field" 
                                                   type="checkbox" 
                                                   data-id="@item.Id" 
                                                   data-field="core"
                                                   @(item.Core ? "checked" : "")>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <div class="form-check form-switch d-inline-block">
                                            <input class="form-check-input toggle-field" 
                                                   type="checkbox" 
                                                   data-id="@item.Id" 
                                                   data-field="ativo"
                                                   @(item.Ativo ? "checked" : "")>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <button type="button" 
                                                class="btn btn-sm btn-outline-danger" 
                                                onclick="confirmDelete(@item.Id, '@item.Arquivo')"
                                                title="Excluir">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox" style="font-size: 4rem; color: #dee2e6;"></i>
                    <p class="text-muted mt-3">Nenhum arquivo cadastrado.</p>
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
                        <i class="bi bi-plus-circle me-1"></i>Adicionar Primeiro Arquivo
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Upload -->
<div class="modal fade" id="uploadModal" tabindex="-1" aria-labelledby="uploadModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Upload" method="post" enctype="multipart/form-data">
                <div class="modal-header">
                    <h5 class="modal-title" id="uploadModalLabel">
                        <i class="bi bi-upload me-2"></i>Adicionar Novo Arquivo
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="file" class="form-label">Selecione o arquivo</label>
                        <input type="file" class="form-control" id="file" name="file" required>
                        <div class="form-text">
                            <i class="bi bi-info-circle me-1"></i>
                            O nome e o SHA256 serão extraídos automaticamente do arquivo.
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-upload me-1"></i>Adicionar Arquivo
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Form oculto para delete -->
<form id="deleteForm" method="post" asp-action="Delete" style="display: none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"></script>
    <script>
        // Toggle de campos editáveis
        document.querySelectorAll('.toggle-field').forEach(function(checkbox) {
            checkbox.addEventListener('change', function() {
                const id = this.dataset.id;
                const field = this.dataset.field;
                const value = this.checked;

                // Desabilita o checkbox durante a atualização
                this.disabled = true;

                fetch('@Url.Action("UpdateField", "Manifest")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `id=${id}&field=${field}&value=${value}`
                })
                .then(response => response.json())
                .then(data => {
                    if (!data.success) {
                        alert('Erro: ' + data.message);
                        // Reverte o estado do checkbox
                        this.checked = !value;
                    }
                    this.disabled = false;
                })
                .catch(error => {
                    alert('Erro ao atualizar campo: ' + error);
                    this.checked = !value;
                    this.disabled = false;
                });
            });
        });

        // Confirmação de exclusão
        function confirmDelete(id, arquivo) {
            if (confirm(`Tem certeza que deseja excluir o arquivo "${arquivo}"?`)) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        }

        // Auto-fechar alertas
        setTimeout(function() {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(function(alert) {
                const bsAlert = new bootstrap.Alert(alert);
                bsAlert.close();
            });
        }, 5000);
    </script>

    <style>
        .page-title {
            color: #2c3e50;
            font-weight: 600;
        }

        .card {
            border: none;
            border-radius: 10px;
        }

        .table thead th {
            border-bottom: 2px solid #dee2e6;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.85rem;
            letter-spacing: 0.5px;
        }

        .table tbody tr {
            transition: all 0.2s;
        }

        .table tbody tr:hover {
            background-color: #f8f9fa;
            transform: scale(1.01);
        }

        .form-check-input {
            cursor: pointer;
            width: 2.5rem;
            height: 1.25rem;
        }

        .form-check-input:checked {
            background-color: #198754;
            border-color: #198754;
        }

        .btn-sm {
            padding: 0.25rem 0.5rem;
        }

        code {
            background-color: #f8f9fa;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
        }

        .modal-header {
            background-color: #f8f9fa;
            border-bottom: 2px solid #dee2e6;
        }
    </style>
}
