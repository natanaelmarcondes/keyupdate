@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4">Sistema KeyUpdate</h1>
        <p class="lead">Selecione uma opção abaixo para começar</p>
    </div>

    <div class="row g-4">
        <!-- Card 1: Empresas -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm hover-card">
                <div class="card-body text-center d-flex flex-column">
                    <div class="mb-3">
                        <i class="bi bi-building display-1 text-primary"></i>
                    </div>
                    <h5 class="card-title">Gerenciar Empresas</h5>
                    <p class="card-text flex-grow-1">
                        Cadastre, edite e visualize empresas. Gerencie código, nome, modo de execução (Local/Servidor) e status ativo/inativo.
                    </p>
                    <a asp-controller="Empresas" asp-action="Index" class="btn btn-primary mt-auto">
                        <i class="bi bi-arrow-right-circle"></i> Acessar
                    </a>
                </div>
            </div>
        </div>

        <!-- Card 2: Tela 2 (Placeholder) -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm hover-card">
                <div class="card-body text-center d-flex flex-column">
                    <div class="mb-3">
                        <i class="bi bi-gear-fill display-1 text-success"></i>
                    </div>
                    <h5 class="card-title">Configurações</h5>
                    <p class="card-text flex-grow-1">
                        Configure parâmetros do sistema, preferências e outras definições importantes.
                    </p>
                    <button class="btn btn-success mt-auto" disabled>
                        <i class="bi bi-arrow-right-circle"></i> Em breve
                    </button>
                </div>
            </div>
        </div>

        <!-- Card 3: Tela 3 (Placeholder) -->
        <div class="col-md-4">
            <div class="card h-100 shadow-sm hover-card">
                <div class="card-body text-center d-flex flex-column">
                    <div class="mb-3">
                        <i class="bi bi-graph-up display-1 text-warning"></i>
                    </div>
                    <h5 class="card-title">Relatórios</h5>
                    <p class="card-text flex-grow-1">
                        Visualize estatísticas, gráficos e relatórios detalhados sobre o sistema.
                    </p>
                    <button class="btn btn-warning mt-auto" disabled>
                        <i class="bi bi-arrow-right-circle"></i> Em breve
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .hover-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .hover-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.2) !important;
        }
    </style>
}
