@model KeyUpdate.Models.ViewModels.ArquivosPermitidosViewModel

@{
    ViewData["Title"] = "Arquivos Permitidos";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Arquivos Permitidos por Empresa</h1>
            <p class="text-muted mb-0">Selecione a empresa e controle os arquivos permitidos.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label for="empresaId" class="form-label">Empresa</label>
                    <select class="form-select" id="empresaId" name="empresaId" onchange="this.form.submit()">
                        <option value="">Selecione uma empresa</option>
                        @foreach (var empresa in Model.Empresas)
                        {
                            if (Model.EmpresaSelecionadaId == empresa.Id)
                            {
                                <option value="@empresa.Id" selected>@empresa.EmpNome (@empresa.EmpCodigo)</option>
                            }
                            else
                            {
                                <option value="@empresa.Id">@empresa.EmpNome (@empresa.EmpCodigo)</option>
                            }
                        }
                    </select>
                </div>
            </form>
        </div>
    </div>

    @if (Model.EmpresaSelecionadaId.HasValue)
    {
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h2 class="h5 mb-1">Arquivos disponíveis</h2>
                        <p class="text-muted mb-0">Arquivos do manifest que não são core.</p>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Arquivo</th>
                                        <th>Tipo</th>
                                        <th class="text-center pe-4">Ação</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.ArquivosDisponiveis.Any())
                                    {
                                        @foreach (var item in Model.ArquivosDisponiveis)
                                        {
                                            <tr>
                                                <td class="ps-4">@item.Arquivo</td>
                                                <td>@item.Tipo</td>
                                                <td class="text-center pe-4">
                                                    <form asp-action="Adicionar" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="empresaId" value="@Model.EmpresaSelecionadaId" />
                                                        <input type="hidden" name="manifestId" value="@item.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-primary">
                                                            <i class="bi bi-arrow-right"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="3" class="text-center text-muted py-4">Nenhum arquivo disponível.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h2 class="h5 mb-1">Arquivos permitidos</h2>
                        <p class="text-muted mb-0">Arquivos vinculados à empresa @Model.EmpresaSelecionadaNome.</p>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Arquivo</th>
                                        <th>Tipo</th>
                                        <th class="text-center">Ativo</th>
                                        <th class="text-center pe-4">Ação</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.ArquivosPermitidos.Any())
                                    {
                                        @foreach (var item in Model.ArquivosPermitidos)
                                        {
                                            <tr>
                                                <td class="ps-4">@item.Arquivo</td>
                                                <td>@item.Tipo</td>
                                                <td class="text-center">
                                                    <div class="form-check form-switch d-inline-block m-0">
                                                        <input class="form-check-input toggle-ativo" type="checkbox" data-id="@item.Id" @(item.Ativo ? "checked" : null) />
                                                    </div>
                                                </td>
                                                <td class="text-center pe-4">
                                                    <form asp-action="Remover" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="empresaId" value="@Model.EmpresaSelecionadaId" />
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center text-muted py-4">Nenhum arquivo permitido cadastrado.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.toggle-ativo').forEach(function (checkbox) {
            checkbox.addEventListener('change', function () {
                const id = this.dataset.id;
                const value = this.checked;
                const element = this;

                element.disabled = true;

                fetch('@Url.Action("AtualizarAtivo", "ArquivosPermitidos")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
                    },
                    body: `id=${encodeURIComponent(id)}&value=${encodeURIComponent(value)}`
                })
                .then(response => response.json())
                .then(data => {
                    if (!data.success) {
                        element.checked = !value;
                        alert(data.message || 'Erro ao atualizar.');
                    }
                })
                .catch(() => {
                    element.checked = !value;
                    alert('Erro ao atualizar.');
                })
                .finally(() => {
                    element.disabled = false;
                });
            });
        });
    </script>
}
