@{
    ViewData["Title"] = "Início";
}

<div class="container-fluid px-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="bg-white rounded-3 shadow-sm p-4 border">
                <h1 class="h3 mb-2">Painel Inicial</h1>
                <p class="text-muted mb-0">Selecione uma das opções abaixo para acessar os cadastros do sistema.</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <a asp-controller="Empresas" asp-action="Index" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100 dashboard-card">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div class="icon-box bg-primary-subtle text-primary">
                                <i class="bi bi-buildings"></i>
                            </div>
                            <i class="bi bi-arrow-right-circle fs-4 text-muted"></i>
                        </div>
                        <h2 class="h5 text-dark mb-2">Empresas</h2>
                        <p class="text-muted mb-0">Acessar cadastro, edição e exclusão de empresas.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-controller="Manifest" asp-action="Index" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100 dashboard-card">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div class="icon-box bg-success-subtle text-success">
                                <i class="bi bi-file-earmark-zip"></i>
                            </div>
                            <i class="bi bi-arrow-right-circle fs-4 text-muted"></i>
                        </div>
                        <h2 class="h5 text-dark mb-2">Arquivos</h2>
                        <p class="text-muted mb-0">Gerenciar upload, hash, status e exclusão dos arquivos do manifest.</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-controller="ArquivosPermitidos" asp-action="Index" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100 dashboard-card">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <div class="icon-box bg-warning-subtle text-warning">
                                <i class="bi bi-folder-check"></i>
                            </div>
                            <i class="bi bi-arrow-right-circle fs-4 text-muted"></i>
                        </div>
                        <h2 class="h5 text-dark mb-2">Arquivos Permitidos</h2>
                        <p class="text-muted mb-0">Controlar os arquivos permitidos por empresa com base no manifest.</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .dashboard-card {
            transition: all .2s ease-in-out;
        }

        .dashboard-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 .75rem 1.5rem rgba(0, 0, 0, .08) !important;
        }

        .icon-box {
            width: 56px;
            height: 56px;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }
    </style>
}
