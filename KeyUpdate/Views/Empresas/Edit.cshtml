@model KeyUpdate.Models.Empresa

@{
    ViewData["Title"] = "Editar Empresa";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h4><i class="bi bi-pencil-square"></i> Editar Empresa</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label class="form-label">ID da Empresa</label>
                            <input type="text" class="form-control" value="@Model.Id" disabled />
                        </div>

                        <div class="mb-3">
                            <label asp-for="EmpCodigo" class="form-label"></label>
                            <input asp-for="EmpCodigo" class="form-control" type="number" placeholder="Digite o código da empresa" />
                            <span asp-validation-for="EmpCodigo" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EmpNome" class="form-label"></label>
                            <input asp-for="EmpNome" class="form-control" placeholder="Digite o nome da empresa" />
                            <span asp-validation-for="EmpNome" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ExeMode" class="form-label"></label>
                            <select asp-for="ExeMode" class="form-select">
                                <option value="LOCAL">Local</option>
                                <option value="SERVIDOR">Servidor</option>
                            </select>
                            <span asp-validation-for="ExeMode" class="text-danger"></span>
                            <div class="form-text">
                                <i class="bi bi-info-circle"></i> Defina se a empresa roda localmente ou em servidor
                            </div>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="Ativo" class="form-check-input" type="checkbox" />
                            <label asp-for="Ativo" class="form-check-label"></label>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Última Atualização</label>
                            <input type="text" class="form-control" value="@Model.AtualizadoEm.ToString("dd/MM/yyyy HH:mm:ss")" disabled />
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Voltar
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check-circle"></i> Atualizar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
}
